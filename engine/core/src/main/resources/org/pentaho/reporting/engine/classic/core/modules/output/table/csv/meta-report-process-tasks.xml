<meta-data xmlns="http://reporting.pentaho.org/namespaces/engine/classic/metadata/1.0">
  <process-task name="table/csv;page-mode=stream"
                class="org.pentaho.reporting.engine.classic.core.modules.output.table.csv.StreamCSVReportProcessTask"
                bundle-name="org.pentaho.reporting.engine.classic.core.modules.output.table.csv.StreamCSVReportProcessTaskBundle"
                expert="false" hidden="true" preferred="false"
                configuration-prefix="org.pentaho.reporting.engine.classic.core.modules.output.table.csv.">
