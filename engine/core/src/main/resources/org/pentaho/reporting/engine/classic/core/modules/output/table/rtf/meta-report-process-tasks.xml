<meta-data xmlns="http://reporting.pentaho.org/namespaces/engine/classic/metadata/1.0">
  <process-task name="table/rtf;page-mode=stream"
                class="org.pentaho.reporting.engine.classic.core.modules.output.table.rtf.StreamRTFReportProcessTask"
                bundle-name="org.pentaho.reporting.engine.classic.core.modules.output.table.rtf.StreamRTFReportProcessTaskBundle"
